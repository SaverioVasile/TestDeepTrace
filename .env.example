# Enable mail sending and choose provider: smtp | ses
APP_MAIL_ENABLED=false
APP_MAIL_PROVIDER=smtp
APP_MAIL_FROM=no-reply@your-verified-domain.com

# SMTP settings (used when APP_MAIL_PROVIDER=smtp)
SPRING_MAIL_HOST=email-smtp.eu-west-1.amazonaws.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=YOUR_SES_SMTP_USERNAME
SPRING_MAIL_PASSWORD=YOUR_SES_SMTP_PASSWORD

# SES API settings (used when APP_MAIL_PROVIDER=ses)
APP_MAIL_SES_REGION=eu-west-1
APP_MAIL_SES_ACCESS_KEY=
APP_MAIL_SES_SECRET_KEY=

APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
